# Local dev uses SQLite automatically; you only need these in production.
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=1
ALLOWED_HOSTS=*
# Production database (Render/Railway/Neon give you this):
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# Admin login over HTTPS needs this set to your deployed origin:
# CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com
# Frontend origin(s) for CORS (comma-separated):
FRONTEND_ORIGINS=*
# Optional: lifts GitHub enrichment rate limit (60/hr -> 5000/hr)
# GITHUB_TOKEN=ghp_xxx
# JWT lifetime in minutes (default 720 = 12h)
TOKEN_TTL_MIN=720
